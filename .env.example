# ------------------------------------------------------------
# AJ — Variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores.
# Nunca versione o .env com credenciais reais.
# ------------------------------------------------------------

# Módulo de settings ativo:
#   Desenvolvimento: config.settings.development
#   Produção:        config.settings.production
DJANGO_SETTINGS_MODULE=config.settings.development

# Django
SECRET_KEY=troque-por-uma-chave-forte-e-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados (usado apenas em produção)
DB_NAME=aj
DB_USER=postgres
DB_PASSWORD=troque-esta-senha
DB_HOST=localhost
DB_PORT=5432
CONN_MAX_AGE=120

# Segurança HTTP (produção)
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=False

# Cache: locmem (padrão) ou redis
CACHE_BACKEND=locmem
REDIS_URL=redis://127.0.0.1:6379/1
